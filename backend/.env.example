# ═══════════════════════════════════════════════
# MARKETPLACE R45 — Variables de entorno
# Copiar como .env y completar con tus valores
# NUNCA subir el .env real a GitHub
# ═══════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────
# Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...  # service_role key (NO la anon key)

# ── RESEND (emails) ──────────────────────────────
# resend.com → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── EMAIL REMITENTE ──────────────────────────────
# Dominio verificado en Resend (o usar onboarding@resend.dev para pruebas)
FROM_EMAIL=alertas@tudominio.com

# ── RAILWAY (solo referencia, se configura en el panel) ──
# railway.app → tu proyecto → Variables

# ── IA GENERATIVA ────────────────────────────────
# google.com/ai/studio → Get API key
GEMINI_API_KEY=tu_clave_gemini_aqui

# ── MERCADOLIBRE API (OAuth) ─────────────────────
# developers.mercadolibre.com.ar → Mis aplicaciones → Tu app
# Necesario para buscar productos en MercadoLibre (la API ahora requiere autenticación)
ML_CLIENT_ID=tu_app_id_aqui
ML_CLIENT_SECRET=tu_secret_key_aqui

# ── ANTHROPIC (Claude IA) ────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AFILIADOS (Opcional para Monetización) ───────
ALIEXPRESS_TAG=tu_codigo_aliexpress_aqui
AMAZON_TAG=tu_codigo_amazon-20_aqui
